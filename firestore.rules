rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedClinic(clinicId) {
      return clinicId in ['kid', 'lungs', 'ab-labs'];
    }

    match /clinics/{clinicId} {
      allow read, write: if isAllowedClinic(clinicId);
    }

    match /clinics/{clinicId}/{document=**} {
      allow read, write: if isAllowedClinic(clinicId);
    }

    match /clinicSettings/{settingId} {
      allow read, write: if isAllowedClinic(settingId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
