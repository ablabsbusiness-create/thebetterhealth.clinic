{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/emr",
      "destination": "/KID/index.html"
    },
    {
      "source": "/emr/assets/:path*",
      "destination": "/KID/assets/:path*"
    },
    {
      "source": "/emr/KID/assets/:path*",
      "destination": "/KID/assets/:path*"
    },
    {
      "source": "/emr/api/:path*",
      "destination": "/KID/api/:path*"
    },
    {
      "source": "/emr/KID/api/:path*",
      "destination": "/KID/api/:path*"
    },
    {
      "source": "/emr/KID/auth-guard.js",
      "destination": "/KID/auth-guard.js"
    },
    {
      "source": "/emr/KID/growth_chart_config.json",
      "destination": "/KID/growth_chart_config.json"
    },
    {
      "source": "/emr/KID/:path*",
      "destination": "/KID/:path*.html"
    },
    {
      "source": "/emr/:path*",
      "destination": "/KID/:path*.html"
    },
    {
      "source": "/KID/:path*",
      "destination": "/KID/:path*.html"
    }
  ]
}
