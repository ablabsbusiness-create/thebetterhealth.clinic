# Firebase web app config (from Firebase console > Project settings > Your apps)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Admin SDK (used by the serverless API routes in /api).
# Same project ID as above. Provide a service account key for local dev /
# any host that isn't using Google's automatic Application Default Credentials.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_SERVICE_ACCOUNT_KEY=paste-the-service-account-json-or-base64-encoded-json-here

# Clinic staff login (protects the main EMR pages).
CLINIC_ACCESS_PASSWORD=change-this-password
CLINIC_SESSION_SECRET=replace-with-a-long-random-secret

# Patient portal session signing secret (separate from the staff session secret).
PATIENT_SESSION_SECRET=replace-with-another-long-random-secret

# MSG91 (patient portal phone OTP login). Get these from msg91.com > OTP > Widgets.
MSG91_AUTH_KEY=your-msg91-auth-key
VITE_MSG91_WIDGET_ID=your-msg91-widget-id
VITE_MSG91_TOKEN_AUTH=your-msg91-token-auth
