{
  "name": "Ab Labs EMR",
  "short_name": "Ab Labs EMR",
  "description": "Standalone EMR web app for Ab Labs clinical workflows.",
  "start_url": "/emr/ab-labs/index.html",
  "scope": "/emr/ab-labs/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
